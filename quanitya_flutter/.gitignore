# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.buildlog/
.history
.svn/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
/build/

# Web related - PowerSync WASM/Worker assets (downloaded by setup_powersync_web.sh)
web/sqlite3.wasm
web/powersync_db.worker.js
web/powersync_sync.worker.js

# Symbolization related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Generated plugin files (auto-generated by Flutter)
ios/Runner/GeneratedPluginRegistrant.*
linux/flutter/generated_plugin_registrant.*
linux/flutter/generated_plugins.*
macos/Flutter/GeneratedPluginRegistrant.*
windows/flutter/generated_plugin_registrant.*
windows/flutter/generated_plugins.*

# Generated code files
*.freezed.dart
*.g.dart
*.config.dart
*.mocks.dart

# Generated l10n files (Flutter internationalization)
lib/l10n/app_localizations.dart
lib/l10n/app_localizations_*.dart

# PowerSync and build configuration
build.yaml

*.env
*.env*
independent_repos/*
updated-md/*
md/*
*.txt
