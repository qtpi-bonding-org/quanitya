<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- App does not track users across apps/websites -->
	<key>NSPrivacyTracking</key>
	<false/>
	<key>NSPrivacyTrackingDomains</key>
	<array/>

	<!-- No data collected and sent to developer.
	     All user data is E2EE (server cannot read it).
	     Analytics, error reporting, and feedback are opt-in, default off, and anonymous. -->
	<key>NSPrivacyCollectedDataTypes</key>
	<array/>

	<!-- Required Reason APIs used by app code.
	     Dependencies (MLKit, GoogleSignIn, etc.) declare their own in their bundles.
	     Flutter engine declares its own since Flutter 3.16. -->
	<key>NSPrivacyAccessedAPITypes</key>
	<array>
		<!-- UserDefaults: used by Flutter framework for app preferences/locale storage -->
		<dict>
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategoryUserDefaults</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<!-- Access app-specific user defaults -->
				<string>CA92.1</string>
			</array>
		</dict>
		<!-- File timestamp APIs: used by Drift/SQLite database for integrity -->
		<dict>
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategoryFileTimestamp</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<!-- Access file timestamps for app's own files -->
				<string>C617.1</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
