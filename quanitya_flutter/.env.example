# Quanitya Flutter App Environment Configuration

# Server URLs - Update these for your deployment
SERVERPOD_URL=http://127.0.0.1:8090

# Note: POWERSYNC_URL is not needed here - Flutter gets the PowerSync endpoint
# from the Serverpod backend response, not from environment variables

# API Keys (optional - for AI features)
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=your_model_here
GEMINI_API_KEY=your_gemini_key_here

# Development settings
DEBUG_MODE=true

# Production example:
# SERVERPOD_URL=https://staging.quanitya.com/
# PowerSync URL comes from server response automatically