# Quanitya Flutter App Environment Configuration

# Server URL
# Development: http://localhost:8080
# Production:  https://api.quanitya.com/
SERVERPOD_URL=http://localhost:8080

# On-device LLM model download URL (Cloudflare R2 with custom domain)
# Example: https://models.quanitya.com/NuExtract-1.5-tiny-Q4_K_M.gguf
MODEL_DOWNLOAD_URL=

# Live API test keys (optional, for bin/ scripts and test/live_api/ only)
# OPENROUTER_API_KEY=
# GEMINI_API_KEY=