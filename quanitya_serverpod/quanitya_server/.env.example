# Quanitya Self-Hosted — Environment Variables
# Copy to .env and set your passwords, then run: ./scripts/deploy.sh

# ── Required ──────────────────────────────────────────────────────────
POSTGRES_PASSWORD=your_secure_password_here
REDIS_PASSWORD=changeme

# ── PowerSync JWK (auto-generated by deploy.sh into .jwk file) ───────
# Do not edit — deploy.sh generates .jwk automatically on first run.

# ── SMTP (optional) ──────────────────────────────────────────────────
# Without SMTP, verification codes are logged to the server console.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@example.com
# SMTP_SSL=false

# ── R2 Archival (optional) ───────────────────────────────────────────
# Needed only to archive old entries (6+ months) to Cloudflare R2.
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=quanitya-archives

# ── Snapshot Backup (optional) ─────────────────────────────────────
# BACKUP_CONCURRENCY=20
