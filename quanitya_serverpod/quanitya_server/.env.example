# Quanitya Serverpod - Development Environment
# Copy this file to .env and fill in the values.

# Database passwords
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_TEST_PASSWORD=your_test_password_here

# Redis passwords
REDIS_PASSWORD=your_redis_password_here
REDIS_TEST_PASSWORD=your_redis_test_password_here

# PowerSync JWK (generate your own RSA key pair)
PS_JWK_N=your_rsa_modulus_here
PS_JWK_E=AQAB
PS_JWK_KID=dev-key-1
